{
  "name": "cad-viewer",
  "version": "1.0.0",
  "description": "Browser-based DXF viewer with annotation and markup",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "vitest run --reporter=verbose tests/backend",
    "test:frontend": "playwright test tests/frontend",
    "test:coverage": "vitest run --coverage tests/backend",
    "audit": "npm audit"
  },
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.22.2",
    "multer": "2.1.1",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "10.1.0",
    "@vitest/coverage-v8": "3.2.4",
    "c8": "10.1.2",
    "supertest": "7.1.3",
    "vitest": "3.2.4"
  }
}
